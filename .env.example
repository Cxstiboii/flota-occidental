# ─── Credenciales del bot ────────────────────────────────────────────────────
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_DISCORD_APP_ID
GUILD_ID=YOUR_DISCORD_GUILD_ID
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/taxi-bot-prod?retryWrites=true&w=majority

# ─── Comportamiento del bot ───────────────────────────────────────────────────
SYNC_COMMANDS_ON_STARTUP=true
COMMAND_SCOPE=guild

# ─── Canales (existentes) ─────────────────────────────────────────────────────
TAXI_CATEGORY_ID=            # Categoría donde se crean los canales de turno
TAXI_PANEL_CHANNEL_ID=       # Canal donde se publica el panel interactivo
TAXI_AUDIT_CHANNEL_ID=       # Canal de auditoría (recibe TODOS los eventos)
TAXI_SHIFT_CHANNEL_PREFIX=turno

# ─── Canales (nuevos) ─────────────────────────────────────────────────────────
ALERTAS_CHANNEL_ID=          # [REQUERIDO] Canal de alertas críticas para @Supervisores
HISTORIAL_CHANNEL_ID=        # Canal público donde se loguean carreras completadas con screenshot
ASCENSOS_CHANNEL_ID=         # Canal donde se anuncian ascensos de rango automáticos
TAXI_PANEL_MESSAGE_ID=       # ID del mensaje fijo del panel (se auto-completa al primer arranque)

# ─── Roles principales ───────────────────────────────────────────────────────
ROLE_TAXISTA_ID=             # ID del rol Taxista (recomendado sobre el nombre)
ROLE_SUPERVISOR_ID=          # ID del rol Supervisor
ROLE_DUENO_ID=               # ID del rol Dueño

ROLE_TAXISTA=Taxista         # Nombre del rol (fallback si no se usa el ID)
ROLE_SUPERVISOR=Supervisor
ROLE_DUENO=Dueño

# ─── Roles automáticos (nuevos) ──────────────────────────────────────────────
ROL_EN_TURNO_ID=             # Rol asignado mientras el taxista tiene un turno activo

ROL_TAXISTA_JUNIOR_ID=       # 1+ carreras totales
ROL_TAXISTA_ACTIVO_ID=       # 20+ carreras totales
ROL_TAXISTA_ESTABLE_ID=      # 75+ carreras totales
ROL_TAXISTA_VETERANO_ID=     # 200+ carreras totales
ROL_TAXISTA_ELITE_ID=        # 500+ carreras totales

# ─── Límites anti-trampa (nuevos) ────────────────────────────────────────────
CARRERA_VALOR_MIN=50         # Valor mínimo aceptado por carrera (en $)
CARRERA_VALOR_MAX=5000       # Valor máximo — superar este límite genera alerta a supervisores
CARRERA_COOLDOWN_MS=60000    # Tiempo mínimo entre carreras en ms (60000 = 1 minuto)
MAX_CARRERAS_POR_TURNO=50    # Máximo de carreras por turno — superar genera alerta

# ─── Sistema de solicitudes de empleo ────────────────────────────────────────
SOLICITUD_CHANNEL_ID=          # Canal #solicitud-de-empleo (botón de aplicar)
SOLICITUD_MESSAGE_ID=          # ID del mensaje fijo (se auto-completa al primer arranque)
SOLICITUDES_CATEGORY_ID=       # Categoría donde se crean los canales de ticket
SOLICITUDES_STAFF_CHANNEL_ID=  # Canal privado de staff donde llegan notificaciones
ROL_PERIODO_PRUEBA_ID=         # Rol "En Período de Prueba" que se asigna al aprobar
ROL_DIRECCION_ID=              # Rol "Dirección" (puede aprobar/rechazar/agendar/blacklist)

# ─── Sistema de tickets de soporte ──────────────────────────────────────────
TICKET_CHANNEL_ID=           # Canal #abrir-ticket (panel con select menu)
TICKET_PANEL_MESSAGE_ID=     # ID del mensaje fijo (se auto-completa al primer arranque)
TICKETS_CATEGORY_ID=         # Categoría donde se crean los canales de ticket [PRIVADO]
TICKETS_STAFF_CHANNEL_ID=    # Canal privado de staff donde llegan notificaciones de nuevos tickets

# ─── Fase 3 — Automatización ─────────────────────────────────────────────────
TIMEZONE=America/Bogota            # Zona horaria para crons y dashboards

# Ranking semanal (publica top 10 por dinero cada lunes 00:00)
RANKING_CHANNEL_ID=                # Canal donde se publica el ranking semanal
RANKING_CRON=0 0 * * 1             # Expresión cron (default: lunes 00:00)

# Resumen mensual (publica estadísticas del mes anterior el día 1 de cada mes)
ESTADISTICAS_CHANNEL_ID=           # Canal #estadisticas-del-mes

# Dashboard en vivo (embed que se actualiza cada 5 min con el estado actual)
DASHBOARD_CHANNEL_ID=              # Canal donde vive el dashboard
DASHBOARD_MESSAGE_ID=              # ID del mensaje fijo (se auto-completa al primer arranque)
DASHBOARD_UPDATE_INTERVAL=300000   # Intervalo de actualización en ms (default: 5 min)
